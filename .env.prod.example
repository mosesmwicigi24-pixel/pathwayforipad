# Production .env template for the Hostinger VPS deploy
# (docker-compose.prod.yml + docker-compose.vps.yml). Copy to /opt/pathway/.env
# on the VPS and fill in real values. NEVER commit the real .env (§5.10) — it is
# git-ignored and lives ONLY on the server. Secrets are referenced by name here.
#
# Compose interpolates these into the stack at `up` time. The variables below are
# the ones the two compose files reference via ${VAR}; the backend also reads the
# usual app secrets (Stripe / M-Pesa / PayPal / KingsChat / OAuth / certs / push)
# from this same file — see .env.example for the full application list.

# --- Database / auth (docker-compose.prod.yml) ---
POSTGRES_PASSWORD=          # openssl rand -hex 32; postgres + the API DATABASE_URL both use it
JWT_SIGNING_KEY=            # openssl rand -base64 48

# --- Image + domain ---
BACKEND_IMAGE=pathway-backend:local   # locally-built image tag (or a GHCR ref)
DOMAIN=pathway.nuruplace.org          # used only by the prod Caddy service (not started on this box)
APP_PUBLIC_URL=https://pathway.nuruplace.org   # base URL in transactional emails

# --- Transactional email via Brevo (docker-compose.vps.yml) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_SERVERNAME=        # left blank for Brevo
SMTP_USER=                  # Brevo SMTP login
SMTP_PASS=                  # Brevo SMTP key
EMAIL_FROM=no-reply@nuruplace.org

# --- Nuru AI (Groq primary, Gemini fallback) + uploads ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
CLOUDINARY_URL=             # cloudinary://<key>:<secret>@<cloud>
