{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read", "Edit", "Write", "Glob", "Grep", "WebFetch", "WebSearch",
      "Bash(pnpm:*)", "Bash(npm:*)", "Bash(npx:*)", "Bash(node:*)",
      "Bash(tsc:*)", "Bash(vitest:*)", "Bash(eslint:*)", "Bash(prettier:*)",
      "Bash(turbo:*)", "Bash(node-pg-migrate:*)", "Bash(psql:*)", "Bash(pg_isready:*)",
      "Bash(docker:*)", "Bash(docker-compose:*)",
      "Bash(git status:*)", "Bash(git add:*)", "Bash(git commit:*)", "Bash(git diff:*)",
      "Bash(git log:*)", "Bash(git checkout:*)", "Bash(git branch:*)", "Bash(git switch:*)",
      "Bash(ls:*)", "Bash(cat:*)", "Bash(grep:*)", "Bash(rg:*)", "Bash(find:*)",
      "Bash(mkdir:*)", "Bash(cp:*)", "Bash(mv:*)", "Bash(sed:*)", "Bash(echo:*)",
      "Bash(curl:*)", "Bash(jq:*)", "Bash(react-native:*)", "Bash(redocly:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Read(./.env)",
      "Read(./**/.env)"
    ]
  }
}
