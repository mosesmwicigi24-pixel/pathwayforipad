# Nuru Place Pathway — environment template (Spec Appendix B.1).
# Copy to .env for local dev. Secrets are referenced by name only; real values
# live in the managed secrets store (§5.10) and are NEVER committed.

# --- Database (§4.4) ---
DATABASE_URL=postgres://nuru:nuru@localhost:6432/nuru          # primary DSN via PgBouncer
DATABASE_REPLICA_URL=postgres://nuru:nuru@localhost:6432/nuru  # read-replica DSN (dashboards/telemetry)

# --- Redis (§1.6, §4.4) — separate logical DBs for sessions/cache/queue ---
REDIS_URL=redis://localhost:6379

# --- Auth / tokens (§5.3) ---
JWT_SIGNING_KEY=changeme-dev-only            # secret: active access-token signing key
JWT_ACCESS_TTL=900                           # access-token lifetime, seconds (15 min)
REFRESH_TTL=2592000                          # refresh-token lifetime, seconds (rotating + reuse detection)

# --- Federated identity (§5.3) ---
KINGSCHAT_OIDC_ISSUER=
KINGSCHAT_OIDC_CLIENT_ID=
KINGSCHAT_OIDC_SECRET=                       # secret
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_SECRET=                         # secret
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_SECRET=                          # secret

# --- Payments (§3.5, §5.6) — sandbox keys only outside production ---
STRIPE_SECRET_KEY=                           # secret
STRIPE_WEBHOOK_SECRET=                       # secret (HMAC webhook verification)

# --- Scripture (§B.1) ---
YOUVERSION_APP_KEY=                          # secret
YOUVERSION_LANGUAGE_RANGES=en;sw             # mandatory to avoid 422s

# --- Media (§4.5) ---
CLOUDINARY_URL=                              # secret

# --- Certificates (§2, §5.5) ---
CERT_SIGNING_KEY=                            # secret: detached-signature key for tamper-evident PDFs

# --- Notifications (§1.5) ---
PUSH_PROVIDER_KEY=                           # secret: APNs/FCM/email dispatch

# --- Platform (§4.1) ---
AWS_REGION=af-south-1                         # primary region (Cape Town)
PORT=8080
NODE_ENV=development

# --- Observability (§4.7) ---
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Features v2 (App. B additions) ---
VIDEO_PROVIDER=cloudinary                     # cloudinary | hls
VIDEO_MAX_HEIGHT=720                          # rendition cap (PRD §7.3 / §D.1)
STORAGE_BUCKET_MEDIA=                         # object store bucket for self-managed HLS
CDN_BASE_URL=                                 # CDN origin for signed media URLs
CAL_MATERIALIZE_HORIZON_DAYS=35              # how far ahead occurrences are realized
CAL_MAX_INSTANCES=500                         # recurrence-expansion cap (§C.4 DoS guard)
