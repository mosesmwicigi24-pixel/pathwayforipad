# Keep the build context lean and force a clean, reproducible install in-image.
**/node_modules
**/dist
**/.turbo
# Stale incremental build-info WITHOUT its dist makes composite `tsc` skip emit, so
# @nuru/shared never builds in-image and the backend can't resolve it. Force a
# clean compile every time.
**/*.tsbuildinfo
.turbo
.git
.env
**/.env
*.log
# NOTE: do not exclude any workspace package dir here — pnpm --frozen-lockfile
# verifies every importer in the lockfile is present.
nuru-place-technical-spec.pdf
