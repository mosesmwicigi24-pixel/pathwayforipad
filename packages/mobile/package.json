{
  "name": "@nuru/mobile",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "react-native start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "assets:link": "react-native-asset",
    "ios": "react-native run-ios",
    "ios:pods": "cd ios && RCT_NEW_ARCH_ENABLED=1 bundle exec pod install",
    "ios:build": "cd ios && xcodebuild -workspace NuruPlace.xcworkspace -scheme NuruPlace -configuration Release -destination 'generic/platform=iOS' -derivedDataPath /tmp/nuru-dd -allowProvisioningUpdates build",
    "ios:clean": "cd ios && xcodebuild -workspace NuruPlace.xcworkspace -scheme NuruPlace clean && rm -rf /tmp/nuru-dd",
    "android": "react-native run-android",
    "android:apk": "cd android && ./gradlew assembleRelease",
    "android:bundle": "cd android && ./gradlew bundleRelease",
    "android:clean": "cd android && ./gradlew clean"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@nuru/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "@reduxjs/toolkit": "^2.2.6",
    "axios": "^1.7.2",
    "lucide-react-native": "^1.17.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-aes-crypto": "^3.3.0",
    "react-native-audio-recorder-player": "^4.5.0",
    "react-native-document-picker": "^9.3.1",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-video": "^6.16.1",
    "react-redux": "^9.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/codegen": "0.86.0",
    "@react-native/gradle-plugin": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/react": "^19.2.0",
    "hermes-compiler": "250829098.0.14",
    "react-native-asset": "^2.3.0",
    "typescript": "^5.8.3",
    "vitest": "^2.0.4"
  }
}
