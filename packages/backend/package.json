{
  "name": "@nuru/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "worker:start": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "migrate:up": "node-pg-migrate up -m migrations -j sql",
    "migrate:down": "node-pg-migrate down -m migrations -j sql",
    "migrate:create": "node-pg-migrate create -m migrations -j sql",
    "seed": "node scripts/seed.mjs",
    "seed:dev": "node scripts/seed-dev.mjs"
  },
  "dependencies": {
    "@nuru/shared": "workspace:*",
    "argon2": "^0.40.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.12.0",
    "pino": "^9.3.1",
    "pino-http": "^10.2.0",
    "stripe": "^16.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "embedded-postgres": "16.6.0-beta.15",
    "node-pg-migrate": "^7.6.1",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "vitest": "^2.0.4"
  }
}
